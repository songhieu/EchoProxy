{
  "name": "echoproxy/sdk-laravel",
  "description": "Laravel SDK for EchoProxy — captures HTTP traffic and ships it to ingest-api. Server middleware + Guzzle middleware + proxy-mode client.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/songhieu/EchoProxy",
  "keywords": ["observability", "http", "proxy", "apm", "laravel", "guzzle", "logging", "echoproxy"],
  "authors": [
    {
      "name": "songhieu",
      "email": "songhieu2516@gmail.com",
      "homepage": "https://github.com/songhieu"
    }
  ],
  "support": {
    "issues": "https://github.com/songhieu/EchoProxy/issues",
    "source":  "https://github.com/songhieu/EchoProxy/tree/main/sdk-laravel",
    "docs":    "https://github.com/songhieu/EchoProxy#readme"
  },
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.5",
    "psr/http-message": "^1.1|^2.0",
    "psr/log": "^1.1|^2.0|^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "illuminate/support": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Echoproxy\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Echoproxy\\Sdk\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Echoproxy\\Sdk\\EchoproxyServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
}
