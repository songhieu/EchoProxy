{
  "name": "echoproxy/sdk-laravel",
  "description": "Laravel SDK for echoproxy — captures HTTP traffic and ships it to ingest-api.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.5",
    "psr/http-message": "^1.1|^2.0",
    "psr/log": "^1.1|^2.0|^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "illuminate/support": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Echoproxy\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Echoproxy\\Sdk\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Echoproxy\\Sdk\\EchoproxyServiceProvider"
      ]
    }
  }
}
