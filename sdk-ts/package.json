{
  "name": "@echoproxy/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the EchoProxy HTTP observability platform — capture inbound + outbound HTTP traffic",
  "license": "MIT",
  "author": "songhieu <songhieu2516@gmail.com>",
  "homepage": "https://github.com/songhieu/EchoProxy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/songhieu/EchoProxy.git",
    "directory": "sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/songhieu/EchoProxy/issues"
  },
  "keywords": [
    "observability",
    "http",
    "proxy",
    "apm",
    "express",
    "fetch",
    "logging",
    "clickhouse",
    "kafka"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js",
      "require": "./dist/proxy.cjs"
    },
    "./ingest": {
      "types": "./dist/ingest.d.ts",
      "import": "./dist/ingest.js",
      "require": "./dist/ingest.cjs"
    },
    "./capture": {
      "types": "./dist/capture.d.ts",
      "import": "./dist/capture.js",
      "require": "./dist/capture.cjs"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --experimental-strip-types src/proxy.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "22.7.4",
    "typescript": "5.6.2"
  }
}
